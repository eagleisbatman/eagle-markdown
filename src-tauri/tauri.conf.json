{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Eagle Markdown",
  "version": "0.1.3",
  "identifier": "com.eagleisbatman.eaglemarkdown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Eagle Markdown",
        "width": 1000,
        "height": 700,
        "minWidth": 480,
        "minHeight": 400,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: http: asset: http://asset.localhost; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A fast, native Markdown viewer",
    "longDescription": "Eagle Markdown is a lightweight, native Markdown viewer built with Tauri and pulldown-cmark. Features include syntax highlighting, live file watching, multi-tab support, GitHub-flavored Markdown, and dark mode.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
